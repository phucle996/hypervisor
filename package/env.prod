APP_TIMEZONE="UTC"
APP_HTTP_PORT="3080"
APP_LOG_LEVEL="info"
APP_PUBLIC_URL="http://localhost:3080"
APP_TRUSTED_PROXIES=""
APP_ALLOWED_ORIGINS=""
ADMIN_ALLOWED_CIDRS="0.0.0.0/0,::/0"

PSQL_HOST="localhost"
PSQL_PORT="5432"
PSQL_USER="postgres"
PSQL_PASSWORD="27012004"
PSQL_DBNAME="hypervisor"
PSQL_SCHEMA="hypervisor"
PSQL_SSLMODE="verify-full"
PSQL_TLS_ENABLED="true"
PSQL_TLS_CA="/etc/aurora-hypervisor/tls/app/ca/ca.crt"
PSQL_TLS_CERT="/etc/aurora-hypervisor/tls/app/postgres/client.crt"
PSQL_TLS_KEY="/etc/aurora-hypervisor/tls/app/postgres/client.key"
PSQL_MAX_CONNS="20"
PSQL_MIN_CONNS="5"
PSQL_MAX_CONN_LIFE="30m"
PSQL_MAX_CONN_IDLE="5m"
PSQL_PING_TIMEOUT="5s"
PSQL_MAX_RETRIES="5"
PSQL_RETRY_INTERVAL="3s"

REDIS_ADDR="localhost:6379"
REDIS_PASSWORD="27012004"
REDIS_DB="0"
REDIS_TLS_ENABLED="true"
REDIS_TLS_CA="/etc/aurora-hypervisor/tls/app/ca/ca.crt"
REDIS_TLS_CERT="/etc/aurora-hypervisor/tls/app/redis/client.crt"
REDIS_TLS_KEY="/etc/aurora-hypervisor/tls/app/redis/client.key"
REDIS_DIAL_TIMEOUT="5s"
REDIS_READ_TIMEOUT="3s"
REDIS_WRITE_TIMEOUT="3s"
REDIS_POOL_SIZE="20"
REDIS_MIN_IDLE_CONNS="5"
REDIS_PING_TIMEOUT="5s"
REDIS_MAX_RETRIES="5"
REDIS_RETRY_INTERVAL="3s"

IAM_GRPC_TARGET="127.0.0.1:9090"
IAM_GRPC_TLS_CA="/etc/aurora-hypervisor/tls/app/ca/ca.crt"
IAM_GRPC_TLS_CERT="/etc/aurora-hypervisor/tls/app/grpc/client.crt"
IAM_GRPC_TLS_KEY="/etc/aurora-hypervisor/tls/app/grpc/client.key"
IAM_GRPC_TLS_SERVER_NAME="iam.auroracloud.local"
IAM_ADMIN_SESSION_REQUEST_TIMEOUT="3s"

GRPC_SERVER_ENABLED="true"
GRPC_SERVER_PORT="9443"
GRPC_SERVER_PUBLIC_ADDR="hypervisor.auroracloud.local:9443"
GRPC_SERVER_TLS_CERT="/etc/aurora-hypervisor/tls/app/grpc/server.crt"
GRPC_SERVER_TLS_KEY="/etc/aurora-hypervisor/tls/app/grpc/server.key"
GRPC_SERVER_CLIENT_CA="/etc/aurora-hypervisor/tls/app/ca/ca.crt"

AGENT_CA_CERT="/etc/aurora-hypervisor/tls/app/ca/ca.crt"
AGENT_CA_KEY="/etc/aurora-hypervisor/tls/app/ca/ca.key"
AGENT_CERT_TTL="720h"
